{
  "info": {
    "name": "Bus Booking API",
    "_postman_id": "d2b7f6c8-8f6a-4f2a-9d21-4cfb9a5bc001",
    "description": "Postman collection for the Bus Booking API with token persistence for protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "bearerToken",
      "value": ""
    },
    {
      "key": "seatNumber",
      "value": "1"
    },
    {
      "key": "seatStatus",
      "value": "OPEN"
    },
    {
      "key": "loginEmail",
      "value": "admin@test.com"
    },
    {
      "key": "loginPassword",
      "value": "password123"
    },
    {
      "key": "passengerName",
      "value": "Test User"
    },
    {
      "key": "passengerEmail",
      "value": "test@example.com"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('stores bearer token from login response', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('token');",
                  "  if (data.token) {",
                  "    pm.collectionVariables.set('bearerToken', data.token);",
                  "    pm.environment.set('bearerToken', data.token);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Seats",
      "item": [
        {
          "name": "Get All Seats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats"]
            }
          },
          "response": []
        },
        {
          "name": "Get Seat By Number",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", ":seatNumber"],
              "variable": [
                {
                  "key": "seatNumber",
                  "value": "{{seatNumber}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Seats By Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/status/:status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "status", ":status"],
              "variable": [
                {
                  "key": "status",
                  "value": "{{seatStatus}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Book Seat",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{bearerToken}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/seat/:seatNumber/book",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "seat", ":seatNumber", "book"],
              "variable": [
                {
                  "key": "seatNumber",
                  "value": "{{seatNumber}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passengerName\": \"{{passengerName}}\",\n  \"passengerEmail\": \"{{passengerEmail}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Release Seat",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{bearerToken}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/seat/:seatNumber/release",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "seat", ":seatNumber", "release"],
              "variable": [
                {
                  "key": "seatNumber",
                  "value": "{{seatNumber}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "response": []
        },
        {
          "name": "Get Seat Owner",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/seats/seat/:seatNumber/owner",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "seats", "seat", ":seatNumber", "owner"],
              "variable": [
                {
                  "key": "seatNumber",
                  "value": "{{seatNumber}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Reset All Seats",
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{bearerToken}}",
                "type": "string"
              }
            ]
          },
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/seats/reset",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "seats", "reset"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}